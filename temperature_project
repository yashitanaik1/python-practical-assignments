# celsius_to_fahrenheit.py
def convert(celsius):
    return (celsius * 9/5) + 32


# fahrenheit_to_celsius.py
def convert(fahrenheit):
    return (fahrenheit - 32) * 5/9


# celsius_to_kelvin.py
def convert(celsius):
    return celsius + 273.15


